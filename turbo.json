{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env",
    "pnpm-lock.yaml"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "dist/**"]
    },
    "lint": {},
    "test": {}
  }
}